-- ========================================
-- VIEWS (Pre-built Queries)
-- ========================================

CREATE VIEW IF NOT EXISTS user_weekly_summary AS
SELECT 
    p.user_id,
    strftime('%W', p.date) as week_number,
    COUNT(*) as total_sessions,
    AVG(p.total_score * 1.0 / 10) as avg_accuracy,
    SUM(p.time_spent) as total_time,
    MAX(p.streak_days) as max_streak
FROM progress p 
GROUP BY p.user_id, week_number;

CREATE VIEW IF NOT EXISTS current_streaks AS
SELECT 
    u.user_id,
    ds.current_streak,
    CASE 
        WHEN ds.current_streak >= 30 THEN '🔥 LEGEND'
        WHEN ds.current_streak >= 15 THEN '🥇 ELITE' 
        WHEN ds.current_streak >= 7 THEN '🥈 PRO'
        WHEN ds.current_streak >= 3 THEN '🥉 GOOD'
        ELSE '💪 KEEP GOING'
    END as streak_status
FROM daily_streaks ds;
