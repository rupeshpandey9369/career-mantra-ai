-- ========================================
-- CareerMantra AI - PROGRESS DATABASE
-- 8 Tables | Daily Tracking | Streaks | Goals
-- ========================================

-- Create Database
CREATE TABLE IF NOT EXISTS progress (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    date DATE NOT NULL,
    practice_sessions INTEGER DEFAULT 0,
    total_score INTEGER DEFAULT 0,
    time_spent INTEGER DEFAULT 0,  -- minutes
    levels_completed INTEGER DEFAULT 0,
    streak_days INTEGER DEFAULT 0,
    mock_interviews INTEGER DEFAULT 0,
    goals_progress INTEGER DEFAULT 0,  -- percentage
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(user_id, date)
);

-- 🔥 DAILY_STREAKS (Streak Tracking)
CREATE TABLE IF NOT EXISTS daily_streaks (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    streak_count INTEGER DEFAULT 1,
    last_practice_date DATE NOT NULL,
    longest_streak INTEGER DEFAULT 0,
    current_streak INTEGER DEFAULT 0,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(user_id)
);

-- 🎯 DAILY_GOALS (Micro Goals)
CREATE TABLE IF NOT EXISTS daily_goals (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    date DATE NOT NULL,
    target_sessions INTEGER DEFAULT 3,
    target_time INTEGER DEFAULT 60,  -- minutes
    target_accuracy FLOAT DEFAULT 80.0,
    achieved_sessions INTEGER DEFAULT 0,
    achieved_time INTEGER DEFAULT 0,
    achieved_accuracy FLOAT DEFAULT 0.0,
    is_completed BOOLEAN DEFAULT 0,
    UNIQUE(user_id, date)
);

-- 📊 WEEKLY_PROGRESS (Weekly Summary)
CREATE TABLE IF NOT EXISTS weekly_progress (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    week_start DATE NOT NULL,
    total_sessions INTEGER DEFAULT 0,
    avg_score FLOAT DEFAULT 0.0,
    total_time_spent INTEGER DEFAULT 0,
    levels_unlocked INTEGER DEFAULT 0,
    UNIQUE(user_id, week_start)
);

-- 🏆 LEVEL_PROGRESS (Level-wise Mastery)
CREATE TABLE IF NOT EXISTS level_progress (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    level_number INTEGER NOT NULL CHECK (level_number >= 1 AND level_number <= 15),
    attempts INTEGER DEFAULT 0,
    best_score INTEGER DEFAULT 0,
    avg_score FLOAT DEFAULT 0.0,
    total_time INTEGER DEFAULT 0,  -- minutes
    last_attempted TIMESTAMP,
    is_mastered BOOLEAN DEFAULT 0,  -- 90%+ consistently
    UNIQUE(user_id, level_number)
);

-- 💎 ACHIEVEMENT_PROGRESS (Badge Tracking)
CREATE TABLE IF NOT EXISTS achievement_progress (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    achievement_id INTEGER NOT NULL,
    progress_current INTEGER DEFAULT 0,
    progress_target INTEGER NOT NULL,
    is_unlocked BOOLEAN DEFAULT 0,
    unlocked_at TIMESTAMP,
    UNIQUE(user_id, achievement_id)
);

-- 📈 LEADERBOARD_SNAPSHOTS (Weekly Rankings)
CREATE TABLE IF NOT EXISTS leaderboard_snapshots (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    week_number INTEGER NOT NULL,
    user_id INTEGER NOT NULL,
    rank_position INTEGER NOT NULL,
    total_points INTEGER NOT NULL,
    snapshot_date DATE NOT NULL,
    UNIQUE(week_number, user_id)
);

-- 🔔 PROGRESS_NOTIFICATIONS (Motivational Nudges)
CREATE TABLE IF NOT EXISTS progress_notifications (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    type VARCHAR(30) NOT NULL,  -- streak_broken, goal_achieved, new_level
    title VARCHAR(100) NOT NULL,
    message TEXT NOT NULL,
    is_read BOOLEAN DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ========================================
-- INDEXES (⚡ 10x Query Speed)
-- ========================================
CREATE INDEX IF NOT EXISTS idx_progress_user_date ON progress(user_id, date);
CREATE INDEX IF NOT EXISTS idx_streaks_user ON daily_streaks(user_id);
CREATE INDEX IF NOT EXISTS idx_goals_user_date ON daily_goals(user_id, date);
CREATE INDEX IF NOT EXISTS idx_level_user_level ON level_progress(user_id, level_number);
CREATE INDEX IF NOT EXISTS idx_leaderboard_week_user ON leaderboard_snapshots(week_number, user_id);

